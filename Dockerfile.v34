# Jetson Voice v3.4 — Clean rebuild for ASR1 streaming (multilanguage mode)
# Removes sherpa-onnx, librosa, and their transitive deps (scipy, numba, etc.)
# that are dead code under LANGUAGE_MODE=multilanguage.
# Base: dustynv onnxruntime with CUDAExecutionProvider (JP6.x, CUDA 12.6)
FROM dustynv/onnxruntime:1.20-r36.4.0

ENV DEBIAN_FRONTEND=noninteractive
ENV LANG=C.UTF-8

# System deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    libasound2 libsndfile1 sox \
    && rm -rf /var/lib/apt/lists/*

# Python deps in single RUN layer (no docker commit chain)
RUN pip3 install --no-cache-dir --index-url https://pypi.org/simple \
    fastapi \
    "uvicorn[standard]" \
    soundfile \
    python-multipart \
    numpy \
    tokenizers \
    "transformers<5" \
    "webrtcvad-wheels>=2.0.14" \
    "cuda-python>=12,<13"

# Qwen3-TTS/ASR TensorRT backend for multilanguage mode
# Install from GitHub release (includes prebuilt .so for Jetson Orin)
RUN pip3 install --no-cache-dir git+https://github.com/suharvest/jetson-qwen3-speech.git@v0.1.0

# Application code
COPY app/ /opt/speech/app/

# Custom voice embeddings (patched into voices.bin on first start)
COPY voices/ /opt/speech/voices/

# Models downloaded on first start based on LANGUAGE_MODE env var.
# Cached in /opt/models volume.
RUN mkdir -p /opt/models

ENV MODEL_DIR=/opt/models \
    NVIDIA_VISIBLE_DEVICES=all \
    CUDA_MODULE_LOADING=LAZY \
    ORT_CUDA_ARENA_EXTEND_STRATEGY=kSameAsRequested

WORKDIR /opt/speech/app
EXPOSE 8000

CMD ["python3", "-m", "uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
