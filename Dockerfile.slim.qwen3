# Jetson Voice + Qwen3 highperf — slim multi-stage build (NX experiment)
#
# Goal: shed the 18.2 GB v3.5-clean image down to ~1.5 GB by:
#   1. multi-stage builder (existing v3.5-clean is the source of Python pkgs)
#   2. ubuntu:22.04 runtime base (no bundled TRT / CUDA)
#   3. host JetPack libs mounted at runtime (TRT 10.3 from host > image 10.4)
#
# Runtime mounts (mandatory):
#   -v /usr/lib/aarch64-linux-gnu:/host-libs:ro
#   -v /usr/local/cuda/lib64:/host-cuda:ro
#   -v <repro-qwen3-bin-dir>:/opt/edgellm-bin:ro      # qwen3_tts_worker + plugin
#   -v <qwen3-models>:/opt/models/qwen3-edgellm:ro
#   -e LD_LIBRARY_PATH=/host-libs:/host-cuda:/usr/local/lib/python3.10/dist-packages/onnxruntime/capi
#   -e EDGE_LLM_TTS_WORKER_BIN=/opt/edgellm-bin/qwen3_tts_worker
#   -e EDGELLM_PLUGIN_PATH=/opt/edgellm-bin/libNvInfer_edgellm_plugin.so
#   -e QWEN3_ARTIFACT_ROOT=/opt/models/qwen3-edgellm
#   -e JETSON_VOICE_PROFILE=multilanguage-qwen-highperf-nx

ARG BUILDER_IMAGE=jetson-voice-speech:v3.5-clean
FROM ${BUILDER_IMAGE} AS builder

RUN python3 -c "import onnxruntime, sherpa_onnx, fastapi; \
    print('ort', onnxruntime.__version__, 'sherpa', sherpa_onnx.__version__, 'fastapi', fastapi.__version__)"

FROM docker.m.daocloud.io/library/ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive LANG=C.UTF-8

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip libpython3.10 \
    libasound2 libsndfile1 sox curl \
    && rm -rf /var/lib/apt/lists/*

# Pin numpy<2 to match onnxruntime ABI from the builder
RUN pip3 install --no-cache-dir --index-url https://pypi.org/simple \
    fastapi "uvicorn[standard]" python-multipart soundfile \
    websockets requests 'numpy<2' \
    piper-phonemize

# Heavy native python packages — copied from builder, not rebuilt
COPY --from=builder /usr/local/lib/python3.10/dist-packages/onnxruntime \
                    /usr/local/lib/python3.10/dist-packages/onnxruntime
COPY --from=builder /usr/local/lib/python3.10/dist-packages/sherpa_onnx \
                    /usr/local/lib/python3.10/dist-packages/sherpa_onnx
COPY --from=builder /usr/local/lib/python3.10/dist-packages/huggingface_hub \
                    /usr/local/lib/python3.10/dist-packages/huggingface_hub
COPY --from=builder /usr/local/lib/python3.10/dist-packages/safetensors \
                    /usr/local/lib/python3.10/dist-packages/safetensors

# SONAME symlink (some packages look for libonnxruntime.so.1)
RUN ln -sf /usr/local/lib/python3.10/dist-packages/onnxruntime/capi/libonnxruntime.so.1.20.0 \
           /usr/local/lib/python3.10/dist-packages/onnxruntime/capi/libonnxruntime.so.1

# Application code — copy from build context (jetson-voice tree)
COPY app/ /opt/speech/app/
COPY configs/ /opt/speech/configs/
COPY voices/ /opt/speech/voices/

# Empty mount points (operator binds real paths at runtime)
RUN mkdir -p /opt/edgellm-bin /opt/models/qwen3-edgellm /opt/qwen3-edgellm-jetson

ENV NVIDIA_VISIBLE_DEVICES=all \
    CUDA_MODULE_LOADING=LAZY \
    MODEL_DIR=/opt/models

WORKDIR /opt/speech/app
EXPOSE 8000
CMD ["python3", "-m", "uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
