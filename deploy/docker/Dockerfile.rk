# syntax=docker/dockerfile:1.6
#
# Seeed Local Voice — Rockchip RK3576 / RK3588 NPU edition
#
# Based on third_party/rkvoice-stream/docker/Dockerfile (system deps + RKNN runtime).
# Adds the seeed-local-voice FastAPI front-end on top, with rkvoice-stream installed
# as an editable package so the RK backend adapter (app/backends/rk/) can import it.
#
# Build (from repo root):
#   docker build -f deploy/docker/Dockerfile.rk -t seeed-local-voice:rk .
#
# Run (RK3576 or RK3588 — profile env switches platform):
#   docker run --privileged --network=host \
#     -v /dev:/dev \
#     -v /home/cat/models:/opt/tts/models:ro \
#     -v /home/cat/qwen3-asr-models:/opt/asr/models:ro \
#     -v /home/cat/rknn-matmul-parallel:/opt/rknn-matmul-parallel:ro \
#     -e PYTHONPATH=/opt/rknn-matmul-parallel \
#     -e SEEED_LOCAL_VOICE_PROFILE=rk3576-default \
#     seeed-local-voice:rk
#
# Models are NOT baked in — bind-mount via -v at runtime.

FROM debian:12-slim

ENV DEBIAN_FRONTEND=noninteractive
ENV LANG=C.UTF-8

# System deps (mirrors rkvoice-stream/docker/Dockerfile)
RUN apt-get update && apt-get install -y --no-install-recommends \
        python3 python3-pip python3-venv \
        libsndfile1 \
        libgomp1 \
        espeak-ng \
        curl \
    && rm -rf /var/lib/apt/lists/*

# Build-time PyPI mirror. Default = Tsinghua (CN-fast); override for non-CN:
#   docker build --build-arg PIP_INDEX=https://pypi.org/simple ...
ARG PIP_INDEX=https://pypi.tuna.tsinghua.edu.cn/simple
ENV PIP_INDEX_URL=${PIP_INDEX}

# Python venv (matches rkvoice-stream base)
RUN python3 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Core scientific + audio deps
RUN pip install --no-cache-dir --index-url ${PIP_INDEX} \
        'numpy<2' \
        soundfile \
        librosa \
        "pysbd>=0.3.4" \
        "silero-vad"

# FastAPI stack
RUN pip install --no-cache-dir --index-url ${PIP_INDEX} \
        fastapi \
        'uvicorn[standard]' \
        python-multipart \
        websockets \
        requests

# Model / tokenizer deps
RUN pip install --no-cache-dir --index-url ${PIP_INDEX} \
        transformers \
        tokenizers \
        pybind11

# CPU ASR/TTS fallback (sherpa-onnx) + onnxruntime
RUN pip install --no-cache-dir --index-url ${PIP_INDEX} \
        sherpa-onnx \
        onnxruntime

# RKNN toolkit lite2 (aarch64 wheel from PyPI)
RUN pip install --no-cache-dir --index-url ${PIP_INDEX} \
        rknn-toolkit-lite2

RUN ldconfig

# Copy seeed-local-voice tree + rkvoice-stream submodule into image
COPY app/                          /opt/speech/app/
COPY configs/                      /opt/speech/configs/
COPY voices/                       /opt/speech/voices/
COPY scripts/                      /opt/speech/scripts/
COPY third_party/rkvoice-stream/   /opt/speech/third_party/rkvoice-stream/

# Install rkvoice-stream as editable so app/backends/rk/ can import it.
RUN pip install --no-cache-dir -e /opt/speech/third_party/rkvoice-stream

# Model dirs (bind-mounted at runtime, not baked)
RUN mkdir -p /opt/tts/models /opt/asr/models /opt/models

ENV MODEL_DIR=/opt/models \
    TTS_MODEL_DIR=/opt/tts/models \
    ASR_MODEL_DIR=/opt/asr/models \
    LD_LIBRARY_PATH=/usr/lib
# NOTE: do NOT bake SEEED_LOCAL_VOICE_PROFILE here. Operator picks via
# SEEED_LOCAL_VOICE_PRESET at docker run time (auto-resolves via
# profile_selector). A baked PROFILE default would silently override
# the operator's PRESET choice because profile_loader resolves PROFILE
# before PRESET.

LABEL org.opencontainers.image.title="Seeed Local Voice (Rockchip)" \
      org.opencontainers.image.source="https://github.com/suharvest/seeed-local-voice" \
      org.opencontainers.image.description="Speech service on Rockchip NPU (RK3576 / RK3588)"

WORKDIR /opt/speech
ENV PYTHONPATH=/opt/speech
EXPOSE 8000

CMD ["python3", "-m", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
