# syntax=docker/dockerfile:1.6
#
# OpenVoiceStream — Raspberry Pi 4 / 5 (linux/arm64, ONNX Runtime CPU EP)
#
# Paraformer streaming ASR + Matcha TTS via sherpa-onnx (CPU only).
#
# Build (from repo root):
#   docker build -f deploy/docker/Dockerfile.rpi \
#     -t sensecraft-missionpack.seeed.cn/solution/seeed-local-voice:rpi-v1.0-onnx .
#
# Run:
#   docker run -p 8621:8000 \
#     -v ~/openvoicestream-rpi/models:/opt/models \
#     openvoicestream:rpi5

FROM debian:12-slim

ENV DEBIAN_FRONTEND=noninteractive
ENV LANG=C.UTF-8

# Build-time PyPI mirror. Default = Tsinghua (CN-fast); override for non-CN:
#   docker build --build-arg PIP_INDEX=https://pypi.org/simple ...
ARG PIP_INDEX=https://pypi.tuna.tsinghua.edu.cn/simple
ENV PIP_INDEX_URL=${PIP_INDEX}

# System deps
RUN apt-get update && apt-get install -y --no-install-recommends \
        python3 python3-pip python3-venv \
        libasound2 libsndfile1 sox curl bzip2 \
    && rm -rf /var/lib/apt/lists/*

# Python deps (CPU-only stack)
RUN pip3 install --no-cache-dir --break-system-packages --index-url ${PIP_INDEX} \
        fastapi \
        "uvicorn[standard]" \
        soundfile \
        python-multipart \
        'numpy<2' \
        sherpa-onnx \
        onnxruntime \
        websockets \
        requests \
        "pysbd>=0.3.4" \
        "webrtcvad-wheels>=2.0.14"

# Application code (post-refactor layout: app/core, app/backends/cpu, app/utils)
COPY app/      /opt/speech/app/
COPY configs/  /opt/speech/configs/

# Model dir (populated at runtime via volume mount)
RUN mkdir -p /opt/models

ENV MODEL_DIR=/opt/models \
    OVS_PROFILE_DEFAULT=rpi5-default \
    LANGUAGE_MODE=zh_en \
    ASR_BACKEND=sherpa \
    TTS_BACKEND=sherpa \
    STREAMING_ASR_PROVIDER=cpu \
    OFFLINE_ASR_PROVIDER=cpu \
    ENSURE_OFFLINE_ASR=1 \
    TTS_PROVIDER=cpu \
    TTS_NUM_THREADS=4 \
    STREAMING_ASR_NUM_THREADS=4
# RPi must not inherit the LANGUAGE_MODE=zh_en -> jetson-zh-en fallback in
# profile_loader. Keep the image pinned to the CPU-only RPi profile unless an
# operator explicitly overrides OVS_PROFILE.

LABEL org.opencontainers.image.title="OpenVoiceStream (Raspberry Pi)" \
      org.opencontainers.image.source="https://github.com/suharvest/openvoicestream" \
      org.opencontainers.image.description="CPU speech service for Raspberry Pi 4/5"

WORKDIR /opt/speech
ENV PYTHONPATH=/opt/speech
EXPOSE 8000

CMD ["python3", "-m", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
