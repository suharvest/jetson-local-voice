# Thin "diff" Dockerfile — bakes the latest app/ tree on top of a previous
# baseline image. Use when the change set is Python-only (no new pip / apt
# dependencies). Builds in seconds because all big layers are inherited.
#
# Build (default base = jetson-v1.11):
#   docker build -f deploy/docker/Dockerfile.jetson.patch \
#       -t openvoicestream:jetson-v1.12 .
#
# Override base:
#   docker build -f deploy/docker/Dockerfile.jetson.patch \
#       --build-arg BASE=openvoicestream:jetson-v1.11 \
#       -t openvoicestream:jetson-v1.12 .
#
# If you added pip deps, do NOT use this — fall back to the full
# Dockerfile.jetson rebuild path.

ARG BASE=openvoicestream:jetson-v1.11
FROM ${BASE}

# Only the Python tree is hot — everything else inherited.
COPY app/      /opt/speech/app/
COPY configs/  /opt/speech/configs/
COPY scripts/  /opt/speech/scripts/

LABEL org.opencontainers.image.title="OpenVoiceStream (Jetson, patched)"
LABEL build.diff-base="${BASE}"
LABEL build.diff-type="python-only"
