{
  "name": "rk3576-default",
  "description": "Rockchip RK3576 NPU profile. Backends are delegated to the rkvoice-stream submodule (third_party/rkvoice-stream); env mirrors the canonical docker-compose defaults from that repo.",
  "asr_backend": "rk.asr",
  "tts_backend": "rk.tts",
  "execution_policy": {
    "mode": "serialized",
    "shared_resource": "npu"
  },
  "env": {
    "RK_PLATFORM": "rk3576",
    "ASR_BACKEND": "qwen3_asr_rk",
    "ASR_DECODER_TYPE": "rkllm",
    "ASR_MODEL_DIR": "/opt/asr/models",
    "RKLLM_LIB_PATH": "/opt/asr/lib/librkllmrt.so",
    "QWEN3_ASR_STREAM_TRUE": "1",
    "TTS_BACKEND": "matcha_rknn",
    "TTS_MODEL_DIR": "/opt/tts/models",
    "MODEL_DIR": "/opt/tts/models",
    "MATCHA_USE_ORT": "1",
    "MATCHA_MODEL": "matcha-s64.rknn",
    "MATCHA_MAX_PHONEMES": "64",
    "MATCHA_MODEL_SEQ_LEN": "80",
    "VOCOS_MODEL": "vocos-16khz-600.rknn",
    "VOCOS_FRAMES": "600"
  }
}
